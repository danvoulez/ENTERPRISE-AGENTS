# LLM Gateway
LLM_GATEWAY_URL=http://localhost:7700
LLM_API_KEY=your-gateway-api-key
LLM_PREMIUM_MODEL=claude-sonnet-4-6
LLM_AUTO_MODEL=qwen2.5-coder:7b

# Repository
REPO_ROOT=/path/to/your/project
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REMOTE=origin
GITHUB_BRANCH=main

# Linear
LINEAR_API_KEY=lin_api_xxxxx
LINEAR_TEAM_KEY=TEAM
LINEAR_PROJECT=project-uuid

# Supabase Realtime
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_CHANNEL=orchestrator-channel

# Webhook
WEBHOOK_PORT=9090
WEBHOOK_SECRET=your-webhook-secret

# Email Notifications
EMAIL_API_URL=https://api.resend.com/emails
EMAIL_API_KEY=re_xxxxx
EMAIL_TO=operator@example.com

# Runtime
POLL_INTERVAL=30000
HEALTH_PORT=8081
DASHBOARD_PORT=8082
